# Neon Database Connection URL
# Get this from your Neon Console: https://console.neon.tech/
# Example: postgresql://user:password@host/database
DATABASE_URL=your_neon_database_url_here

# Secret key for securing the cron job endpoint (optional)
# If set, the cron job will require this secret in the Authorization header
CRON_SECRET=your_cron_secret_here
