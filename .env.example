# Neon Database Connection URL
# Get this from your Neon Console: https://console.neon.tech/
# Example: postgresql://user:password@host/database
DATABASE_URL=your_neon_database_url_here

# Edge Store Configuration
# Get these from your Edge Store Dashboard: https://dashboard.edgestore.dev/
EDGE_STORE_ACCESS_KEY=your_edge_store_access_key_here
EDGE_STORE_SECRET_KEY=your_edge_store_secret_key_here
